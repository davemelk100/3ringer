    "react-hook-form": "^7.50.0",
    "react-intersection-observer": "^9.13.1",
    "tailwind-merge": "^2.1.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.22.4",
    "zustand": "^4.5.0"
